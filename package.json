{
  "name": "harbour",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "effect": "3.21.3"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "build:tui": "bun run --cwd apps/tui build",
    "check:migrations": "bun run --cwd packages/db db:migration:check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "vitest run",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run lint && bun run test && bun run typecheck && bun run check:migrations && bun run format:check",
    "sync": "bun run --cwd apps/tui sync",
    "sync:json": "bun run --cwd apps/tui sync:json",
    "sync:compiled": "bun run build:tui && bun run --cwd apps/tui sync:compiled",
    "sync:compiled:json": "bun run build:tui && bun run --cwd apps/tui sync:compiled:json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "prettier": "^3.8.3",
    "turbo": "^2.9.10",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
