{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./packages/config/harbour.schema.json",
  "title": "Harbour Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project"
      }
    }
  },
  "required": ["projects"],
  "$defs": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "modules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["name", "repo", "modules"]
    }
  }
}
