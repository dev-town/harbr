{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./packages/config/harbour.schema.json",
  "title": "Harbour Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project"
      }
    },
    "windows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/window"
      }
    }
  },
  "required": ["projects"],
  "$defs": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "modules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "windows": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "$ref": "#/$defs/window"
              }
            ]
          }
        }
      },
      "required": ["name", "repo", "modules"]
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "panes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pane"
          }
        }
      },
      "required": ["name", "panes"]
    },
    "pane": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["name"]
    }
  }
}
