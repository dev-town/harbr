{
  "$id": "https://raw.githubusercontent.com/dev-town/harbr/main/packages/config/harbr.schema.json",
  "title": "Harbr Config",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "windows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "panes": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "command": {
                  "anyOf": [
                    { "type": "string", "minLength": 1 },
                    {
                      "minItems": 1,
                      "type": "array",
                      "items": { "type": "string", "minLength": 1 }
                    }
                  ]
                },
                "cwd": { "type": "string", "minLength": 1 }
              },
              "required": ["name"],
              "additionalProperties": false
            }
          }
        },
        "required": ["name", "panes"],
        "additionalProperties": false
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "repo": { "type": "string", "minLength": 1 },
          "modules": {
            "minItems": 1,
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "windows": {
            "type": "array",
            "items": {
              "anyOf": [
                { "type": "string", "minLength": 1 },
                {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "minLength": 1 },
                    "panes": {
                      "minItems": 1,
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string", "minLength": 1 },
                          "command": {
                            "anyOf": [
                              { "type": "string", "minLength": 1 },
                              {
                                "minItems": 1,
                                "type": "array",
                                "items": { "type": "string", "minLength": 1 }
                              }
                            ]
                          },
                          "cwd": { "type": "string", "minLength": 1 }
                        },
                        "required": ["name"],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": ["name", "panes"],
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        "required": ["name", "repo"],
        "additionalProperties": false
      }
    }
  },
  "required": ["projects"],
  "additionalProperties": false
}
