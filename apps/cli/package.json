{
  "name": "@harbour/cli",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@harbour/config": "workspace:*",
    "@harbour/reconciler": "workspace:*",
    "effect": "catalog:"
  },
  "scripts": {
    "build": "bun build --compile --minify --sourcemap src/index.ts --outfile dist/harbour-sync",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "start": "bun src/index.ts",
    "test": "vitest run src/format.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
