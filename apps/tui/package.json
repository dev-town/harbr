{
  "name": "@harbr/tui",
  "version": "0.1.0-beta.1",
  "private": true,
  "type": "module",
  "dependencies": {
    "@effect/opentelemetry": "0.63.0",
    "@effect/platform": "0.96.1",
    "@harbr/config": "workspace:*",
    "@harbr/db": "workspace:*",
    "@harbr/domain": "workspace:*",
    "@harbr/git": "workspace:*",
    "@harbr/reconciler": "workspace:*",
    "@harbr/runtime-tmux": "workspace:*",
    "@opentui/core": "^0.2.16",
    "@opentui/keymap": "^0.2.16",
    "@opentui/react": "^0.2.16",
    "effect": "catalog:",
    "react": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "exports": {
    ".": "./src/index.tsx"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "dev": "bun --watch src/index.tsx",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "start": "bun src/index.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "sync": "bun src/index.tsx sync",
    "sync:json": "bun src/index.tsx sync --json",
    "sync:compiled": "./dist/harbr sync",
    "sync:compiled:json": "./dist/harbr sync --json",
    "profile:up": "bun src/index.tsx profile up",
    "profile:down": "bun src/index.tsx profile down",
    "profile:status": "bun src/index.tsx profile status"
  },
  "devDependencies": {
    "@types/react": "^19.2.17"
  }
}
