{
  "name": "@harbour/tui",
  "private": true,
  "type": "module",
  "dependencies": {
    "@harbour/config": "workspace:*",
    "@harbour/db": "workspace:*",
    "@harbour/domain": "workspace:*",
    "@harbour/reconciler": "workspace:*",
    "@harbour/runtime-tmux": "workspace:*",
    "@opentui/core": "^0.2.16",
    "@opentui/keymap": "^0.2.16",
    "@opentui/react": "^0.2.16",
    "effect": "catalog:",
    "react": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "exports": {
    ".": "./src/index.tsx"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "dev": "bun --watch src/index.tsx",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "start": "bun src/index.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "sync": "bun src/index.tsx sync",
    "sync:json": "bun src/index.tsx sync --json",
    "sync:compiled": "./dist/harbour sync",
    "sync:compiled:json": "./dist/harbour sync --json"
  },
  "devDependencies": {
    "@types/react": "^19.2.17"
  }
}
